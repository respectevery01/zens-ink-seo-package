# zens.ink configuration — copy to .env and fill in your values

# ── Serper.dev (for kd analysis) ─────────────────────────────
# Free key at https://serper.dev (2500 free searches)
SERPER_API_KEY=

# ── Brave Search API (for volume estimation) ─────────────────
# Free key at https://api.search.brave.com/ (2000 queries/mo)
BRAVE_API_KEY=

# ── Bing Webmaster Tools ──────────────────────────────────────
# Free API key from https://www.bing.com/webmasters/home
# Preferences -> API key
BING_API_KEY=

# ── Google Search Console ─────────────────────────────────────
# Your verified site URL in GSC
# Domain property:  sc-domain:example.com
# URL prefix:       https://example.com/
GSC_SITE_URL=

# Path to OAuth credentials (created by setup_gsc.py)
# Default: ~/.config/gcloud/application_default_credentials.json
# ADC_PATH=

# ── Google OAuth (for setup_gsc.py only) ──────────────────────
# Create a Desktop OAuth client:
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
